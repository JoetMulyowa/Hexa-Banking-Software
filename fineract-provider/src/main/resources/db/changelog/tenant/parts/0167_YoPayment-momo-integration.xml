<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Create yo_payment_transactions table -->
    <changeSet id="1" author="surepayltd">
        <createTable tableName="yo_payment_transactions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="loan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_yo_payment_loan" references="m_loan(id)"/>
            </column>
            <column name="loan_transaction_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_yo_payment_loan_transaction" references="m_loan_transaction(id)"/>
            </column>
            <column name="middleware_reference_no" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="date_of" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="is_reversed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="status_code" type="VARCHAR(10)">
                <constraints nullable="true"/>
            </column>
            <column name="status_desc" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="vendor_tran_id" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="error_msg" type="VARCHAR(1000)">
                <constraints nullable="true"/>
            </column>
            <column name="request_body" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="response_body" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Add auto increment with explicit column data type but remove incrementBy which is not supported by MariaDB -->
        <addAutoIncrement tableName="yo_payment_transactions" columnName="id" columnDataType="BIGINT" startWith="1"/>
    </changeSet>

    <!-- Add YO PAYMENT payment type -->
    <changeSet id="2" author="surepayltd">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_payment_type WHERE code_name = 'YO_PAYMENT_MOMO_PAYMENT'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_payment_type">
            <column name="value" value="Yo Payment Mobile Money"/>
            <column name="description" value="Payment via Yo Payment Mobile Money"/>
            <column name="is_cash_payment" valueBoolean="false"/>
            <column name="order_position" value="5"/>
            <column name="code_name" value="YO_PAYMENT_MOMO_PAYMENT"/>
            <column name="is_system_defined" valueBoolean="false"/>
        </insert>
    </changeSet>

    <!-- Add global configuration for YO PAYMENT mobile money -->
    <changeSet id="3" author="surepayltd">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM c_configuration WHERE name = 'enable-yo-payment-mobile-money-payment'
            </sqlCheck>
        </preConditions>
        <insert tableName="c_configuration">
            <column name="name" value="enable-yo-payment-mobile-money-payment"/>
            <column name="value" valueBoolean="false"/>
            <column name="description" value="If enabled, allows Yo Payment mobile money for loan disbursements and repayments"/>
            <column name="enabled" valueBoolean="true"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="plugin_name" value="NULL"/>
        </insert>
    </changeSet>

    <!-- Add indexes to yo_payment_transactions table -->
    <changeSet id="4" author="surepayltd">
        <createIndex tableName="yo_payment_transactions" indexName="idx_yo_payment_transactions_loan_id">
            <column name="loan_id"/>
        </createIndex>
        <createIndex tableName="yo_payment_transactions" indexName="idx_yo_payment_transactions_loan_transaction_id">
            <column name="loan_transaction_id"/>
        </createIndex>
        <createIndex tableName="yo_payment_transactions" indexName="idx_yo_payment_transactions_middleware_reference_no">
            <column name="middleware_reference_no"/>
        </createIndex>
        <createIndex tableName="yo_payment_transactions" indexName="idx_yo_payment_transactions_vendor_tran_id">
            <column name="vendor_tran_id"/>
        </createIndex>
    </changeSet>

    <!-- Add related permissions -->
    <changeSet id="5" author="surepayltd">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'CHECK_TRANSACTION_YO_MOMO'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="transaction_momo"/>
            <column name="code" value="CHECK_TRANSACTION_YO_MOMO"/>
            <column name="entity_name" value="LOAN"/>
            <column name="action_name" value="CHECK_TRANSACTION_YO_MOMO"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>
